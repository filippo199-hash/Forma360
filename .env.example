# ─────────────────────────────────────────────────────────────────────────────
# Forma360 environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# This file is parsed by packages/shared/src/env.ts at boot (wired in PR 2).
# ─────────────────────────────────────────────────────────────────────────────

# Node environment: "development" | "test" | "production"
NODE_ENV=development

# Public app URL (e.g. https://forma360.com, or http://localhost:3000 locally)
APP_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (pg URI).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forma360

# ─── Redis ───────────────────────────────────────────────────────────────────
# Used by BullMQ and better-auth secondary session storage.
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random 32+ byte string. Rotate carefully — rotating invalidates sessions.
BETTER_AUTH_SECRET=replace-me-with-32-random-bytes-min
# Base URL better-auth uses for callbacks and cookie domain scoping.
BETTER_AUTH_URL=http://localhost:3000

# ─── Object storage (Cloudflare R2) ──────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=forma360-dev
# Public URL for serving uploaded assets (custom R2 domain or R2 public URL).
R2_PUBLIC_URL=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
# "Forma360 <noreply@forma360.com>" or similar. Must be from a verified domain.
RESEND_FROM=

# Controls how transactional email is delivered.
#   "resend"  — real delivery via Resend (production, staging)
#   "console" — writes the email payload (including verification links) to the
#               structured logger. Only permitted when NODE_ENV != "production";
#               boot will fail if combined with NODE_ENV=production.
EMAIL_DELIVERY=console

# ─── Observability ───────────────────────────────────────────────────────────
# Server-side Sentry DSN (worker + Next server routes).
SENTRY_DSN=
# Client-side Sentry DSN exposed to the browser bundle.
NEXT_PUBLIC_SENTRY_DSN=

# pino log level: "trace" | "debug" | "info" | "warn" | "error" | "fatal"
LOG_LEVEL=info
