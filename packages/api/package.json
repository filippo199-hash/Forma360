{
  "name": "@forma360/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./trpc": {
      "types": "./src/trpc.ts",
      "default": "./src/trpc.ts"
    },
    "./context": {
      "types": "./src/context.ts",
      "default": "./src/context.ts"
    },
    "./router": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@forma360/auth": "workspace:^",
    "@forma360/db": "workspace:^",
    "@forma360/permissions": "workspace:^",
    "@forma360/shared": "workspace:^",
    "@trpc/server": "^11.0.0",
    "rrule": "^2.8.1",
    "superjson": "^2.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "drizzle-orm": "^0.45.0",
    "vitest": "^2.1.0"
  }
}
