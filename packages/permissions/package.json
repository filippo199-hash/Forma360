{
  "name": "@forma360/permissions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./catalogue": {
      "types": "./src/catalogue.ts",
      "default": "./src/catalogue.ts"
    },
    "./requirePermission": {
      "types": "./src/requirePermission.ts",
      "default": "./src/requirePermission.ts"
    },
    "./admins": {
      "types": "./src/admins.ts",
      "default": "./src/admins.ts"
    },
    "./seed": {
      "types": "./src/seed.ts",
      "default": "./src/seed.ts"
    },
    "./rules": {
      "types": "./src/rules.ts",
      "default": "./src/rules.ts"
    },
    "./access": {
      "types": "./src/access.ts",
      "default": "./src/access.ts"
    },
    "./dependents": {
      "types": "./src/dependents.ts",
      "default": "./src/dependents.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:bootstrap": "tsx src/scripts/bootstrap-tenant.ts"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@forma360/db": "workspace:^",
    "@forma360/shared": "workspace:^",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.0"
  }
}
