{
  "name": "@forma360/jobs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./queues": {
      "types": "./src/queues.ts",
      "default": "./src/queues.ts"
    },
    "./enqueue": {
      "types": "./src/enqueue.ts",
      "default": "./src/enqueue.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.720.0",
    "@aws-sdk/lib-storage": "^3.720.0",
    "@forma360/db": "workspace:^",
    "@forma360/permissions": "workspace:^",
    "@forma360/shared": "workspace:^",
    "@sentry/node": "^8.48.0",
    "bullmq": "^5.30.0",
    "drizzle-orm": "^0.45.0",
    "ioredis": "^5.4.1",
    "rrule": "^2.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
