{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "composite": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "noEmit": true,
    "incremental": true
  },
  "include": ["src/**/*", "app/**/*", "next-env.d.ts"],
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/db" },
    { "path": "../../packages/auth" },
    { "path": "../../packages/api" },
    { "path": "../../packages/i18n" },
    { "path": "../../packages/ui" }
  ]
}
